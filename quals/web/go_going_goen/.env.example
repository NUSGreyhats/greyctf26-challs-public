POSTGRES_DB=go_going_goen
POSTGRES_USER=gogoinggoen_pg_user
POSTGRES_PASSWORD=61622f97d222b7bf2b7fef3ca48fbce7112ca7d039440ca6d5d5561de4aec0bc
# Exploits need roughly 30 simultaneous DB transactions per actively exploiting team.
# Shared instance: one global pool of 200 server connections for all teams.
POSTGRES_MAX_CONNECTIONS=250
# Host-side backend development with dev/db/docker-compose.yml. That helper DB
# binds to a random 127.0.0.1 port; run `make db-up` to see the assigned port.
DATABASE_URL=postgresql+psycopg://gogoinggoen_pg_user:61622f97d222b7bf2b7fef3ca48fbce7112ca7d039440ca6d5d5561de4aec0bc@127.0.0.1:5432/go_going_goen
# Root docker-compose.yml backend uses its in-container PgBouncer on loopback.
# start.sh picks a free listen port when PGBOUNCER_LISTEN_PORT=0 (default).
# The root Postgres service is Compose-network-only at db:5432.
APP_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:6432/go_going_goen
PGBOUNCER_DB_HOST=db
PGBOUNCER_DB_PORT=5432
PGBOUNCER_DB_NAME=go_going_goen
PGBOUNCER_DB_USER=gogoinggoen_app
PGBOUNCER_DB_PASSWORD=gogoinggoen_app_password
PGBOUNCER_LISTEN_PORT=0
# transaction mode is required for the stage 2 race to be feasible: in
# session mode each psycopg.connect holds one server conn for the entire
# psycopg session, so 1337 concurrent /add requests need 1337 server
# conns simultaneously. Transaction mode releases the server conn after
# every COMMIT, so the 30-connection team budget can be reused across a
# larger client burst instead of requiring one upstream connection per
# client request.
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=200
PGBOUNCER_MIN_POOL_SIZE=0
PGBOUNCER_RESERVE_POOL_SIZE=0
# Long enough that the stage 2 attack wave doesn't 500-storm the server
# if a solver fires too aggressively. Default 30s left the box wedged
# for ~5 minutes after one bad burst.
PGBOUNCER_QUERY_WAIT_TIMEOUT=120
PGBOUNCER_CLIENT_USER=postgres
PGBOUNCER_CLIENT_PASSWORD=postgres
# Cookie HMAC key. 32 bytes / 64 hex chars (256-bit, RFC 2104).
#   generate: python -c 'import secrets; print(secrets.token_hex(32))'
SESSION_SECRET=b5b12bc5bbb4d93abd08363125ba3217bedcdb276d294c41473acc513da40efb
# Stage 1 wordbank/diagnostics secret. Whatever you set is internally
# hashed to a 16-hex-char (64-bit) token used for both the wordbank
# subset seed and the /diagnostics ==compare. The intent: regardless of
# what the operator sets here, solvers always face a fixed 16-position
# search space on the timing-leak path, and offline subset brute force
# stays infeasible at 64 bits. Any non-empty string is fine; we still
# recommend something high-entropy in case the hash gets weakened.
#   generate: python -c 'import secrets; print(secrets.token_hex(8))'
PINPOINT_SECRET=7ae5255ada894bca
# Diagnostics timing-oracle signal target per matched token byte. The backend
# calibrates one fixed hash-round count at process startup/import time to hit
# this CPU-delay target.
# 10-20ms is enough on the tested low-jitter path; raise this for noisy
# high-latency routes. Set PINPOINT_DIAGNOSTICS_ATTEST_ROUNDS to bypass
# calibration with a fixed round count.
PINPOINT_DIAGNOSTICS_TARGET_MS=20
# PINPOINT_DIAGNOSTICS_ATTEST_ROUNDS=
SINGLETON_USERNAME=team
# Deploy-wide salt mixed into internal team_id derivation. Treat like SESSION_SECRET.
#   generate: python -c 'import secrets; print(secrets.token_hex(32))'
TEAM_ID_SALT=30dca98af37e7913b740c658289619c11b16b5a87046030c602b7895a26af664

# --- CTFd Team Token auth (see docs/PRD-TRD-shared-instance-team-token-auth.md) ---
CTFD_RESOLVE_URL=
CTFD_TEAM_TOKEN_PLUGIN_SECRET=
CTFD_CHALLENGE_ID=

# Stage 3 buy-flag string returned after clearing the ledger puzzle. Not used for
# team identity or CTFd scoring — teams still submit the competition flag on CTFd.
FLAG=grey{placeholder_flag_maybe}
APP_HOST=0.0.0.0
APP_PORT=8000
# Host port published by compose.yml for the bundled backend service.
BACKEND_PUBLISH_PORT=34167
# Uvicorn in-flight cap for the shared instance. Tune after load testing.
APP_LIMIT_CONCURRENCY=300
# How many TCP connections may sit in the accept queue before the
# kernel refuses new ones. Default uvicorn is 2048; keep it modest so
# bursts back-pressure quickly.
APP_BACKLOG=128
# HTTP keep-alive idle timeout in seconds. Default 5; explicit for
# clarity. Lower if you see lingering TCP from misbehaving clients.
APP_TIMEOUT_KEEP_ALIVE=5
# Required to expose Prometheus /metrics. Defaults to a generated dev secret; override in production.
METRICS_TOKEN=58a3e3e137d8117321b04138b3d4d9d7f27c8503a2ba2fba625c0510b065d563
# Operator bearer/query token for /api/admin/* routes.
ADMIN_TOKEN=
# Query latency (seconds) above which db_slow_queries_total increments.
DB_SLOW_QUERY_SECONDS=0.1
