<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
      .gallery-card img { width: 100%; height: 200px; object-fit: cover; }
      .navbar-brand { font-weight: 700; letter-spacing: -0.5px; }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary mb-4">
      <div class="container">
        <a class="navbar-brand" href="/">Greyhats Gallery</a>
        <a href="/upload" class="btn btn-primary btn-sm">Upload</a>
      </div>
    </nav>

    <main class="container">
      <% if (message) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <% if (photos.length === 0) { %>
        <div class="text-center py-5">
          <h4 class="text-body-secondary">No photos uploaded yet.</h4>
          <a href="/upload" class="btn btn-outline-primary mt-3">Upload your first photo</a>
        </div>
      <% } else { %>
        <div class="row g-3">
          <% photos.forEach((photo) => { %>
            <div class="col-6 col-md-4 col-lg-3">
              <div class="card gallery-card h-100">
                <a href="<%= photo.url %>" target="_blank">
                  <img src="<%= photo.url %>" class="card-img-top" alt="<%= photo.filename %>">
                </a>
                <div class="card-body p-2">
                  <p class="card-text text-truncate small mb-1"><%= photo.filename %></p>
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="badge bg-secondary"><%= Math.ceil(photo.size / 1024) %> KB</span>
                    <form action="/photos/delete" method="post" class="m-0">
                      <input type="hidden" name="path" value="<%= photo.relativePath %>">
                      <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1">Delete</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
